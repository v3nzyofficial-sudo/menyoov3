    p.Size = UDim2.new(0, size, 0, size)
    p.Position = UDim2.new(math.random(), 0, 1.1, 0) -- Появляются снизу
    p.BackgroundColor3 = Color3.new(1, 1, 1)
    p.BackgroundTransparency = 0.92 -- Делаем их очень призрачными и мягкими
    p.BorderSizePixel = 0
    
