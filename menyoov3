-- [[ 6. ИСПРАВЛЕННАЯ ЛОГИКА AIMBOT (SMART WALLCHECK) ]]

local Circle = Drawing.new("Circle")
Circle.Thickness = 1.5; Circle.Color = Color3.new(1,1,1); Circle.NumSides = 100
local cAlpha = 0; local RightClick = false

-- Слушатели мыши
UserInputService.InputBegan:Connect(function(i,g) if not g and i.UserInputType == Enum.UserInputType.MouseButton2 then RightClick = true end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton2 then RightClick = false end end)

RunService.RenderStepped:Connect(function()
    local MousePos = UserInputService:GetMouseLocation()
    Circle.Position = MousePos; Circle.Radius = _G.Config.Combat.Fov
    
    -- Проверка активности (Hold Mode или Toggle)
    local isAim = _G.Config.Combat.Aimbot and (not _G.Config.Combat.HoldMode or RightClick)
    
    -- Плавность круга
    local targetAlpha = (isAim and _G.Config.Combat.ShowCircle) and 0.8 or 0
    cAlpha = cAlpha + (targetAlpha - cAlpha) * 0.15
    Circle.Transparency = cAlpha; Circle.Visible = cAlpha > 0.01
    
    if isAim then
        local t; local d = _G.Config.Combat.Fov
        
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(_G.Config.Combat.Part) and p.Character:FindFirstChild("Humanoid") then
                -- 1. Team Check
                if _G.Config.Combat.TeamCheck and p.Team == LocalPlayer.Team then continue end
                
                -- 2. Health Check
                if p.Character.Humanoid.Health <= 0 then continue end
                
                local head = p.Character[_G.Config.Combat.Part]
                local pos, vis = Camera:WorldToViewportPoint(head.Position)
                
                if vis then
                    -- 3. SMART WALL CHECK (Фикс "невидимых стен")
                    if _G.Config.Combat.WallCheck then
                        -- Проверяем, есть ли между камерой и головой врага ПЛОТНЫЕ объекты
                        local parts = Camera:GetPartsObscuringTarget({head.Position}, {LocalPlayer.Character, p.Character})
                        if #parts > 0 then 
                            -- Если что-то мешает обзору, пропускаем этого игрока
                            continue 
                        end
                    end
                    
                    local mag = (Vector2.new(pos.X, pos.Y) - MousePos).Magnitude
                    if mag < d then d = mag; t = head end
                end
            end
        end
        
        -- Наведение
        if t then 
            local Smoothness = _G.Config.Combat.Smooth / 100
            local MainCF = CFrame.new(Camera.CFrame.Position, t.Position)
            Camera.CFrame = Camera.CFrame:Lerp(MainCF, Smoothness) 
        end
    end
end)


