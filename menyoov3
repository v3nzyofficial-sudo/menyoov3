local function ToggleEverything()
    local IsActive = not ScreenGui.Enabled -- ScreenGui это твое основное меню
    
    -- Переключаем видимость меню и слоя частиц
    ScreenGui.Enabled = IsActive
    GlobalFX.Enabled = IsActive
    
    -- Плавный блюр (натекание за 0.5 сек)
    game:GetService("TweenService"):Create(ScreenBlur, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = IsActive and 22 or 0
    }):Play()
    
    -- Очистка частиц при закрытии (чтобы не ели FPS)
    if not IsActive then
        GlobalFX:ClearAllChildren()
    end
end

-- Привязка к клавише INSERT
game:GetService("UserInputService").InputBegan:Connect(function(input, gpe)
    -- Убираем проверку gpe, чтобы открывалось всегда
    if input.KeyCode == Enum.KeyCode.Insert then
        ToggleEverything()
    end
end)

