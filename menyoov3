    local targetPos = UDim2.new(p.Position.X.Scale + (math.random(-25, 25)/100), 0, -0.2, 0)
    local tween = game:GetService("TweenService"):Create(p, TweenInfo.new(math.random(12, 22), Enum.EasingStyle.Linear), {
