local function SpawnBigParticle()
    task.spawn(function()
        local p = Instance.new("Frame")
        p.Name = "AmbientParticle"
        p.Parent = ParticleContainer
        
        -- Рандомный размер (от 4 до 12 пикселей)
        local size = math.random(4, 12)
        p.Size = UDim2.new(0, size, 0, size)
        
        -- Начальная позиция снизу экрана
        p.Position = UDim2.new(math.random(), 0, 1.1, 0)
        p.BackgroundColor3 = Color3.new(1, 1, 1)
        p.BackgroundTransparency = 0.8 -- Делаем их очень мягкими
        p.BorderSizePixel = 0
        
        -- Скругление, чтобы частицы были мягкими кружками
        local pCorner = Instance.new("UICorner")
        pCorner.CornerRadius = UDim.new(1, 0)
        pCorner.Parent = p
        
        -- Рандомный угол поворота
        p.Rotation = math.random(0, 360)
        
        -- Математика полета
        local targetPos = UDim2.new(p.Position.X.Scale + (math.random(-20, 20)/100), 0, -0.2, 0)
        local randomTime = math.random(7, 15) -- Медленный полет
        local randomRotation = p.Rotation + math.random(-180, 180)
        
        -- Анимация движения, вращения и затухания
        local tweenInfo = TweenInfo.new(randomTime, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(p, tweenInfo, {
            Position = targetPos,
            Rotation = randomRotation,
            BackgroundTransparency = 1 -- Плавно исчезают к верху
        })
        
        tween:Play()
        
        -- Удаление после анимации
        tween.Completed:Connect(function()
            p:Destroy()
        end)
    end)
end

