local function ApplyESP(p)
    local Tracer = Drawing.new("Line")
    RunService.RenderStepped:Connect(function()
        if p.Character and p.Character:FindFirstChild("Head") and p ~= LocalPlayer and p.Character.Humanoid.Health > 0 then
            local head = p.Character.Head; local hum = p.Character.Humanoid; local pos, vis = Camera:WorldToViewportPoint(head.Position)
            local tag = head:FindFirstChild("Menyoo_Tag") or Instance.new("BillboardGui", head)
            tag.Name = "Menyoo_Tag"; tag.AlwaysOnTop = true; tag.Size = UDim2.new(0,100,0,40); tag.ExtentsOffset = Vector3.new(0,2.5,0)
            local l = tag:FindFirstChild("L") or Instance.new("TextLabel", tag)
            l.Name = "L"; l.BackgroundTransparency = 1; l.Size = UDim2.new(1,0,0,15); l.Font = "GothamBold"; l.TextSize = 10; l.TextColor3 = p.TeamColor.Color; l.TextStrokeTransparency = 0.5
            local hbg = tag:FindFirstChild("HBG") or Instance.new("Frame", tag)
            hbg.Name = "HBG"; hbg.Size = UDim2.new(0,50,0,3); hbg.Position = UDim2.new(0.5,-25,0,18); hbg.BackgroundColor3 = Color3.new(0,0,0); hbg.BorderSizePixel = 0
            local hf = hbg:FindFirstChild("HF") or Instance.new("Frame", hbg)
            hf.Name = "HF"; hf.BorderSizePixel = 0; hf.Size = UDim2.new(hum.Health/hum.MaxHealth, 0, 1, 0)
            
            local hp = hum.Health
            local hpColor = hp > 50 and Color3.new(0, 1, 0):Lerp(Color3.new(0, 0.4, 0), (100-hp)/50) or hp > 30 and Color3.new(1, 1, 0):Lerp(Color3.new(0.6, 0.6, 0), (50-hp)/20) or Color3.new(1, 0, 0):Lerp(Color3.new(0.5, 0, 0), (30-hp)/30)
            hf.BackgroundColor3 = hpColor
            
            tag.Enabled = vis and (_G.Config.Visuals.ShowNames or _G.Config.Visuals.ShowDistance or _G.Config.Visuals.ShowHealth)
            hbg.Visible = _G.Config.Visuals.ShowHealth
            l.Text = (_G.Config.Visuals.ShowNames and p.DisplayName or "") .. (_G.Config.Visuals.ShowDistance and " ["..math.floor((head.Position - Camera.CFrame.Position).Magnitude).."m]" or "")
            Tracer.Visible = vis and _G.Config.Visuals.ShowTracers
            Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); Tracer.To = Vector2.new(pos.X, pos.Y); Tracer.Color = p.TeamColor.Color
            local hi = p.Character:FindFirstChild("Menyoo_HL") or Instance.new("Highlight", p.Character)
            hi.Name = "Menyoo_HL"; hi.Enabled = _G.Config.Visuals.Esp; hi.FillColor = p.TeamColor.Color; hi.FillTransparency = 0.6
        else Tracer.Visible = false end
        if not p.Parent then Tracer:Remove() end
    end)
end
